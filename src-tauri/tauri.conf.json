{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Multi CLI Studio",
  "version": "0.1.0",
  "identifier": "com.local.multi-cli-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Multi CLI Studio",
        "width": 1480,
        "height": 860,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Desktop orchestration shell for Codex, Claude, and Gemini CLIs.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "Multi CLI Studio",
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-",
      "entitlements": "./Entitlements.plist",
      "infoPlist": "./Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5NzQ0MTVGNzgzMDczRkEKUldUNmN6QjRYMEYwNlg0NWZHaFNKNUMydEhVQW1YOFMvL2xEZ0RoQjZtRkZkYXZBMTRUTFVyQVQK",
      "endpoints": [
        "https://github.com/Austin-Patrician/multi-cli-studio/releases/latest/download/latest.json"
      ]
    }
  }
}
