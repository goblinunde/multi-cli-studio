{
  "name": "multi-cli-studio",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "tsc -b && vite build --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts",
    "version:sync": "node ./scripts/sync-version.mjs",
    "version:check": "node ./scripts/sync-version.mjs --check",
    "release:setup": "node ./scripts/setup-desktop-release.mjs",
    "release:check": "node ./scripts/release-preflight.mjs",
    "release:feed": "node ./scripts/configure-release-feed.mjs",
    "tauri:dev": "node ./scripts/run-tauri.mjs dev",
    "tauri:build": "node ./scripts/run-tauri.mjs build",
    "tauri:android": "node ./scripts/run-tauri.mjs android"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xyflow/react": "^12.10.2",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "lucide-react": "^0.562.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1",
    "xterm": "^5.3.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}
